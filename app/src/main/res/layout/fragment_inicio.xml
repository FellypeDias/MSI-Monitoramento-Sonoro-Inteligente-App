<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:id="@+id/scrol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/StatusCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeColor="#EEF2F7"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/textStatusDoSistema"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status do Sistema"
                        android:textColor="@color/cinza_legenda"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/textStatusOnlineOffline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Offline"
                        android:textColor="#111827"
                        android:textSize="18sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/textStatusDoSistema" />

                    <TextView
                        android:id="@+id/textAtualizacaoStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Sem dados"
                        android:textColor="@color/cinza_legenda"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/textStatusOnlineOffline" />

                    <ImageView
                        android:id="@+id/imgCheckStatus"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/ic_circulo_24"
                        app:tint="#22C55E" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/EstatisticaCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="false"
                app:strokeColor="#B3C4CB"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#9ED6EEFF">

                    <TextView
                        android:id="@+id/textEstattisticas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="18dp"
                        android:text="Estatisticas"
                        android:textColor="@color/black"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/imgEventosHoje"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_marginStart="60dp"
                        android:layout_marginTop="15dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/textEstattisticas"
                        app:srcCompat="@drawable/ic_launcher_background" />

                    <TextView
                        android:id="@+id/textR_EventosHoje"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="13dp"
                        android:text="0"
                        android:textColor="@color/black"
                        app:layout_constraintEnd_toEndOf="@+id/imgEventosHoje"
                        app:layout_constraintStart_toStartOf="@+id/imgEventosHoje"
                        app:layout_constraintTop_toBottomOf="@+id/imgEventosHoje" />

                    <TextView
                        android:id="@+id/textEventoshoje"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:text="Eventos Hoje"
                        android:textColor="#8A8A8A"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="@+id/textR_EventosHoje"
                        app:layout_constraintStart_toStartOf="@+id/textR_EventosHoje"
                        app:layout_constraintTop_toBottomOf="@+id/textR_EventosHoje" />

                    <ImageView
                        android:id="@+id/imgAlertasAtivos"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        app:layout_constraintBottom_toBottomOf="@+id/imgEventosHoje"
                        app:layout_constraintEnd_toStartOf="@+id/imgTempoOnline"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintStart_toEndOf="@+id/imgEventosHoje"
                        app:layout_constraintTop_toTopOf="@+id/imgEventosHoje"
                        app:layout_constraintVertical_bias="0.0"
                        app:srcCompat="@drawable/ic_launcher_background" />

                    <ImageView
                        android:id="@+id/imgTempoOnline"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_marginEnd="60dp"
                        app:layout_constraintBottom_toBottomOf="@+id/imgAlertasAtivos"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/imgAlertasAtivos"
                        app:layout_constraintVertical_bias="0.0"
                        app:srcCompat="@drawable/ic_launcher_background" />

                    <TextView
                        android:id="@+id/textR_AlertasAtivos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="13dp"
                        android:text="0"
                        android:textColor="@color/black"
                        app:layout_constraintEnd_toEndOf="@+id/imgAlertasAtivos"
                        app:layout_constraintStart_toStartOf="@+id/imgAlertasAtivos"
                        app:layout_constraintTop_toBottomOf="@+id/imgAlertasAtivos" />

                    <TextView
                        android:id="@+id/textAlertasAtivos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:text="Alertas Ativos"
                        android:textColor="@color/cinza_legenda"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="@+id/textR_AlertasAtivos"
                        app:layout_constraintStart_toStartOf="@+id/textR_AlertasAtivos"
                        app:layout_constraintTop_toBottomOf="@+id/textR_AlertasAtivos" />

                    <TextView
                        android:id="@+id/textR_TempoOnline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="13dp"
                        android:text="0h"
                        android:textColor="@color/black"
                        app:layout_constraintEnd_toEndOf="@+id/imgTempoOnline"
                        app:layout_constraintStart_toStartOf="@+id/imgTempoOnline"
                        app:layout_constraintTop_toBottomOf="@+id/imgTempoOnline" />

                    <TextView
                        android:id="@+id/textTempoOnline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:text="Tempo Online"
                        android:textColor="@color/cinza_legenda"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="@+id/textR_TempoOnline"
                        app:layout_constraintStart_toStartOf="@+id/textR_TempoOnline"
                        app:layout_constraintTop_toBottomOf="@+id/textR_TempoOnline" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/GraficoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeColor="#EEF2F7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txtGraficoTitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Atividade da Semana"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtGraficoSubtitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Acionamentos por dia"
                        android:textColor="@color/cinza_legenda"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:id="@+id/chartContainer"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:weightSum="7">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/chartValue1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="0"
                                android:textColor="#111827"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <View
                                android:id="@+id/chartBar1"
                                android:layout_width="14dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_chart_bar" />

                            <TextView
                                android:id="@+id/chartLabel1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Seg"
                                android:textColor="@color/cinza_legenda"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/chartValue2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="0"
                                android:textColor="#111827"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <View
                                android:id="@+id/chartBar2"
                                android:layout_width="14dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_chart_bar" />

                            <TextView
                                android:id="@+id/chartLabel2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Ter"
                                android:textColor="@color/cinza_legenda"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/chartValue3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="0"
                                android:textColor="#111827"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <View
                                android:id="@+id/chartBar3"
                                android:layout_width="14dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_chart_bar" />

                            <TextView
                                android:id="@+id/chartLabel3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Qua"
                                android:textColor="@color/cinza_legenda"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/chartValue4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="0"
                                android:textColor="#111827"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <View
                                android:id="@+id/chartBar4"
                                android:layout_width="14dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_chart_bar" />

                            <TextView
                                android:id="@+id/chartLabel4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Qui"
                                android:textColor="@color/cinza_legenda"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/chartValue5"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="0"
                                android:textColor="#111827"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <View
                                android:id="@+id/chartBar5"
                                android:layout_width="14dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_chart_bar" />

                            <TextView
                                android:id="@+id/chartLabel5"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Sex"
                                android:textColor="@color/cinza_legenda"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/chartValue6"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="0"
                                android:textColor="#111827"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <View
                                android:id="@+id/chartBar6"
                                android:layout_width="14dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_chart_bar" />

                            <TextView
                                android:id="@+id/chartLabel6"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Sab"
                                android:textColor="@color/cinza_legenda"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/chartValue7"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="0"
                                android:textColor="#111827"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <View
                                android:id="@+id/chartBar7"
                                android:layout_width="14dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_chart_bar" />

                            <TextView
                                android:id="@+id/chartLabel7"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Dom"
                                android:textColor="@color/cinza_legenda"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/HistoricoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeColor="#EEF2F7"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/texthistorico"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Historico Recente"
                        android:textColor="#111827"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvHistorico"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/texthistorico" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
