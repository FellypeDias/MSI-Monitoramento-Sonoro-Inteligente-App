<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Ponto (tipo do evento) -->
    <View
        android:id="@+id/dotLeft"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/pontolaranja"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Ponto (status/alerta) no lugar do ícone -->
    <View
        android:id="@+id/dotRight"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/pontoverde"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="12dp"
        android:text="Alerta de movimento detectado"
        android:textColor="#111827"
        android:textSize="12sp"
        app:layout_constraintStart_toEndOf="@id/dotLeft"
        app:layout_constraintEnd_toStartOf="@id/dotRight"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtHora"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="2dp"
        android:text="10:34"
        android:textColor="#9CA3AF"
        android:textSize="11sp"
        app:layout_constraintStart_toEndOf="@id/dotLeft"
        app:layout_constraintEnd_toStartOf="@id/dotRight"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo" />

</androidx.constraintlayout.widget.ConstraintLayout>
